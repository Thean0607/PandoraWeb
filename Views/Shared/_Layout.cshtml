@{
    var cart = Session["Cart"] as List<PandoraWeb.ViewModels.CartItemVM>;
    int cartCount = cart != null ? cart.Sum(c => c.Quantity) : 0;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Pandora</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/assets/css/global.css">
    <link rel="stylesheet" href="~/assets/css/components/buttons.css">
    <link rel="stylesheet" href="~/assets/css/components/navbar.css">
    <link rel="stylesheet" href="~/assets/css/components/product-card.css">
    <link rel="stylesheet" href="~/assets/css/components/footer.css">
    <link rel="stylesheet" href="~/assets/css/components/forms.css">
    <link rel="stylesheet" href="~/assets/css/components/quantity-input.css">
    <link rel="stylesheet" href="~/assets/css/components/section-title.css">
    <link rel="stylesheet" href="~/assets/css/components/breadcrumb.css">
    <link rel="stylesheet" href="~/assets/css/index.css">
    <link rel="stylesheet" href="~/assets/css/profile.css">
    @RenderSection("Styles", required: false)
</head>
<body>

    <!-- Header / Navbar -->
    <nav class="navbar navbar-expand-lg fixed-top navbar-dark">
        <div class="container">
            <a class="navbar-brand" href="@Url.Action("Index", "Home")">PANDORA</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item">
                        <a class="nav-link @(ViewBag.ActiveMenu == "Home" ? "active" : "")" href="@Url.Action("Index", "Home")">Trang Chủ</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewBag.ActiveMenu == "Category" ? "active" : "")" href="@Url.Action("Category", "Product")">Bộ Sưu Tập</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewBag.ActiveMenu == "Stores" ? "active" : "")" href="@Url.Action("Stores", "Home")">Cửa Hàng</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewBag.ActiveMenu == "Contact" ? "active" : "")" href="@Url.Action("Contact", "Home")">Liên Hệ</a>
                    </li>

                </ul>
                <div class="d-flex align-items-center mt-3 mt-lg-0">
                    <form class="d-flex align-items-center me-3 position-relative" action="@Url.Action("Category", "Product")" method="get" style="max-width: 200px;">
                        <div class="input-group input-group-sm">
                            <input type="text" id="searchInput" class="form-control rounded-start-pill border-end-0 bg-transparent text-white" name="search" placeholder="Tìm kiếm..." aria-label="Search" style="box-shadow: none; border-color: rgba(255,255,255,0.2);" autocomplete="off">
                            <button class="btn btn-outline-secondary bg-transparent border-start-0 rounded-end-pill" type="submit" style="border-color: rgba(255,255,255,0.2);">
                                <i class="fas fa-search text-white"></i>
                            </button>
                        </div>
                        <div id="searchSuggestions" class="dropdown-menu w-100 mt-1 shadow-lg border-0" style="display: none; position: absolute; top: 100%; left: 0; max-height: 400px; overflow-y: auto;">
                        </div>
                    </form>
                    
                    <a href="@Url.Action("Cart", "Order")" class="nav-icon position-relative me-3">
                        <i class="fas fa-shopping-bag"></i>
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" id="cart-badge" style="font-size: 0.6rem;">@cartCount</span>
                    </a>

                    @if (Session["FullName"] != null)
                    {
                        <div class="dropdown d-inline-block">
                            <a href="#" class="nav-icon dropdown-toggle d-flex align-items-center text-decoration-none" id="profileDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="fas fa-user-circle text-primary-gold"></i>
                                <span class="ms-2 text-white fw-medium d-none d-md-inline-block" style="font-family: 'Inter', sans-serif; font-size: 0.8rem;">@Session["FullName"]</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-2" aria-labelledby="profileDropdown">
                                <li>
                                    <div class="px-3 py-2 border-bottom mb-1">
                                        <div class="fw-bold">@Session["FullName"]</div>
                                        <small class="text-muted">@Session["Role"]</small>
                                    </div>
                                </li>
                                @if (Session["Role"]?.ToString() == "Admin" || Session["Role"]?.ToString() == "Manager")
                                {
                                    <li><a class="dropdown-item" href="@Url.Action("Index", "Admin")"><i class="fas fa-crown text-warning me-2"></i>Bảng điều khiển Quản trị</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                }
                                <li><a class="dropdown-item" href="@Url.Action("Profile", "Account")"><i class="far fa-id-badge me-2"></i>Hồ sơ cá nhân</a></li>
                                <li><a class="dropdown-item" href="@Url.Action("Orders", "Order")"><i class="fas fa-box me-2"></i>Đơn hàng của tôi</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="@Url.Action("Logout", "Account")"><i class="fas fa-sign-out-alt me-2"></i>Đăng xuất</a></li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a href="@Url.Action("Login", "Account")" class="btn btn-outline-light btn-sm rounded-pill px-3 ms-2 font-serif">Đăng Nhập</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    @RenderBody()

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="row">
                <div class="col-lg-4 col-md-6 mb-4 mb-lg-0">
                    <a href="@Url.Action("Index", "Home")" class="navbar-brand text-white mb-3 d-inline-block">PANDORA</a>
                    <p class="mb-4">Mang đến vẻ đẹp hoàn mỹ và sự tự tin cho phái đẹp thông qua những thiết kế trang sức tinh tế, hiện đại và sang trọng.</p>
                    <div class="social-icons">
                        <a href="#"><i class="fab fa-facebook-f"></i></a>
                        <a href="#"><i class="fab fa-instagram"></i></a>
                        <a href="#"><i class="fab fa-pinterest-p"></i></a>
                        <a href="#"><i class="fab fa-youtube"></i></a>
                    </div>
                </div>
                <div class="col-lg-2 col-md-6 mb-4 mb-lg-0">
                    <h5 class="footer-heading">Liên Kết Nhỏ</h5>
                    <a href="@Url.Action("Index", "Home")" class="footer-link">Trang Chủ</a>
                    <a href="@Url.Action("Category", "Product")" class="footer-link">Sản Phẩm</a>
                    <a href="@Url.Action("About", "Home")" class="footer-link">Về Chúng Tôi</a>
                    <a href="@Url.Action("Stores", "Home")" class="footer-link">Hệ Thống Cửa Hàng</a>
                    <a href="@Url.Action("Contact", "Home")" class="footer-link">Liên Hệ</a>
                </div>
                <div class="col-lg-2 col-md-6 mb-4 mb-lg-0">
                    <h5 class="footer-heading">Hỗ Trợ</h5>
                    <a href="#" class="footer-link">Chính sách bảo hành</a>
                    <a href="#" class="footer-link">Chính sách đổi trả</a>
                    <a href="#" class="footer-link">Hướng dẫn đo size</a>
                    <a href="@Url.Action("Faq", "Home")" class="footer-link">Câu hỏi thường gặp</a>
                </div>
                <div class="col-lg-4 col-md-6">
                    <h5 class="footer-heading">Đăng Ký Nhận Tin</h5>
                    <p>Nhận ngay thông tin về các bộ sưu tập mới và ưu đãi đặc biệt.</p>
                    <form class="d-flex">
                        <input type="email" class="form-control me-2" placeholder="Email của bạn">
                        <button type="submit" class="btn btn-gold text-nowrap">Đăng Ký</button>
                    </form>
                </div>
            </div>
            <hr class="border-secondary mt-5 mb-4">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                    &copy; 2026 Pandora. All rights reserved.
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <img src="~/assets/images/payment-methods.png" alt="Payment Methods" height="30" onerror="this.style.display='none'">
                </div>
            </div>
        </div>
    </footer>

    <!-- Toast Container -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1100;">
        <div id="cartToast" class="toast align-items-center text-white bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="d-flex">
                <div class="toast-body">
                    <i class="fas fa-check-circle me-2"></i> Đã thêm sản phẩm vào giỏ hàng!
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        </div>
    </div>

    @if (Session["CustomerId"] == null)
    {
        <!-- Promo Modal -->
        <div class="modal fade" id="promoModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content text-center" style="border: none; border-radius: 15px; overflow: hidden; background-color: #fcfcfc;">
                    <div class="modal-header border-0 pb-0 justify-content-end" style="position: absolute; right: 0; z-index: 10;">
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" style="background-color: rgba(255,255,255,0.8); margin: 10px; border-radius: 50%;"></button>
                    </div>
                    <div class="modal-body p-0">
                        <img src="https://images.unsplash.com/photo-1599643478514-4a4e02632616?q=80&w=600&auto=format&fit=crop" class="img-fluid" alt="Promo" style="height: 250px; width: 100%; object-fit: cover;">
                        <div class="p-4 pt-4">
                            <h3 class="font-serif mb-2 text-primary-gold">Chào mừng đến với Pandora!</h3>
                            <p class="text-muted mb-4 small">Đăng nhập ngay hôm nay để nhận voucher giảm giá <strong>10%</strong> cho đơn hàng đầu tiên cùng nhiều đặc quyền hấp dẫn dành riêng cho thành viên.</p>
                            <a href="@Url.Action("Login", "Account")" class="btn btn-gold w-100 py-2 mb-2">Đăng Nhập Nhận Ưu Đãi</a>
                            <button type="button" class="btn btn-link text-muted text-decoration-none small" data-bs-dismiss="modal">Không, cám ơn. Bỏ qua</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/assets/js/main.js?v=@DateTime.Now.Ticks"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const searchInput = document.getElementById('searchInput');
            const suggestionsBox = document.getElementById('searchSuggestions');
            let timeout = null;

            if(searchInput && suggestionsBox) {
                searchInput.addEventListener('input', function () {
                    clearTimeout(timeout);
                    const query = this.value.trim();
                    
                    if (query.length < 2) {
                        suggestionsBox.style.display = 'none';
                        return;
                    }

                    timeout = setTimeout(() => {
                        fetch(`@Url.Action("SearchSuggestions", "Product")?query=${encodeURIComponent(query)}`)
                            .then(res => res.json())
                            .then(data => {
                                suggestionsBox.innerHTML = '';
                                if (data.length > 0) {
                                    data.forEach(item => {
                                        const html = `
                                            <a href="${item.DetailUrl}" class="dropdown-item d-flex align-items-center py-2 border-bottom" style="white-space: normal;">
                                                <img src="${item.ImageUrl}" class="rounded me-2 object-fit-cover" style="width: 40px; height: 40px;" onerror="this.src='https://images.unsplash.com/photo-1605100804763-247f67b2548e?q=80&w=600'">
                                                <div class="flex-grow-1 overflow-hidden">
                                                    <div class="fw-bold text-truncate text-dark" style="font-size: 0.85rem;">${item.ProductName}</div>
                                                    <div class="text-danger fw-bold" style="font-size: 0.75rem;">${item.PriceFormatted}</div>
                                                </div>
                                            </a>`;
                                        suggestionsBox.insertAdjacentHTML('beforeend', html);
                                    });
                                } else {
                                    suggestionsBox.innerHTML = '<div class="p-3 text-center text-muted small">Không tìm thấy sản phẩm</div>';
                                }
                                suggestionsBox.style.display = 'block';
                            });
                    }, 300);
                });

                document.addEventListener('click', function (e) {
                    if (!searchInput.contains(e.target) && !suggestionsBox.contains(e.target)) {
                        suggestionsBox.style.display = 'none';
                    }
                });
            }

            @if (Session["CustomerId"] == null)
            {
                <text>
                if (!localStorage.getItem('promoPopupShown')) {
                    setTimeout(function() {
                        var pModal = document.getElementById('promoModal');
                        if (pModal) {
                            var promoModal = new bootstrap.Modal(pModal);
                            promoModal.show();
                            localStorage.setItem('promoPopupShown', 'true');
                        }
                    }, 2000);
                }
                </text>
            }
        });
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>



