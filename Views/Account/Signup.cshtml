@{
    Layout = null;
    ViewBag.Title = "Signup";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng Ký - Pandora</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/assets/css/global.css">
    <link rel="stylesheet" href="~/assets/css/components/buttons.css">
    <link rel="stylesheet" href="~/assets/css/components/navbar.css">
    <link rel="stylesheet" href="~/assets/css/components/product-card.css">
    <link rel="stylesheet" href="~/assets/css/components/footer.css">
    <link rel="stylesheet" href="~/assets/css/components/forms.css">
    <link rel="stylesheet" href="~/assets/css/components/quantity-input.css">
    <link rel="stylesheet" href="~/assets/css/components/section-title.css">
    <link rel="stylesheet" href="~/assets/css/components/breadcrumb.css">
    <link rel="stylesheet" href="~/assets/css/auth.css?v=2">
</head>
<body>

    <div class="auth-container">
        <div class="auth-overlay"></div>
        <div class="auth-card signup-card">
            <div class="text-center mb-4">
                <a href="@Url.Action("Index", "Home")" class="auth-brand m-0">PANDORA</a>
                <p class="auth-subtitle mt-2">Tạo tài khoản mới</p>
            </div>
            
            <form method="post" action="@Url.Action("Signup", "Account")">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger" role="alert">
                        @ViewBag.Error
                    </div>
                }
                <div class="row g-3">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Họ</label>
                        <input type="text" name="lastName" class="form-control py-2" placeholder="Ví dụ: Nguyễn" autocomplete="family-name" required oninvalid="this.setCustomValidity('Vui lòng điền thông tin này.')" oninput="this.setCustomValidity('')">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Tên</label>
                        <input type="text" name="firstName" class="form-control py-2" placeholder="Ví dụ: Văn A" autocomplete="given-name" required oninvalid="this.setCustomValidity('Vui lòng điền thông tin này.')" oninput="this.setCustomValidity('')">
                    </div>
                </div>
                
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input type="email" name="email" class="form-control py-2" placeholder="Nhập địa chỉ email" autocomplete="email" required oninvalid="this.setCustomValidity('Vui lòng điền thông tin này.')" oninput="this.setCustomValidity('')">
                </div>
                <div class="mb-3">
                    <label class="form-label">Số điện thoại</label>
                    <input type="tel" name="phone" class="form-control py-2" placeholder="Nhập số điện thoại" autocomplete="tel" required oninvalid="this.setCustomValidity('Vui lòng điền thông tin này.')" oninput="this.setCustomValidity('')">
                </div>
                <div class="mb-3">
                    <label class="form-label">Mật khẩu</label>
                    <input type="password" name="password" class="form-control py-2" placeholder="Tạo mật khẩu" autocomplete="new-password" minlength="6" required oninvalid="this.setCustomValidity('Vui lòng điền thông tin này.')" oninput="this.setCustomValidity('')">
                </div>
                <div class="mb-4">
                    <label class="form-label">Xác nhận mật khẩu</label>
                    <input type="password" name="confirmPassword" class="form-control py-2" placeholder="Nhập lại mật khẩu" autocomplete="new-password" minlength="6" required oninvalid="this.setCustomValidity('Vui lòng điền thông tin này.')" oninput="this.setCustomValidity('')">
                </div>
                
                <div class="form-check mb-4">
                    <input class="form-check-input" type="checkbox" value="" id="termsCheck" required oninvalid="this.setCustomValidity('Bạn cần đồng ý với các điều khoản.')" oninput="this.setCustomValidity('')">
                    <label class="form-check-label text-muted fs-7" for="termsCheck">
                        Tôi đồng ý với các <a href="#" class="text-white">Điều khoản dịch vụ</a> và <a href="#" class="text-white">Chính sách bảo mật</a> của Pandora.
                    </label>
                </div>

                <button type="submit" class="btn btn-gold w-100 py-2 mb-3">Đăng Ký</button>
                
                <div class="text-center mt-3">
                    <span class="text-muted">Đã có tài khoản?</span> <a href="@Url.Action("Login", "Account")" class="text-primary-gold text-decoration-none fw-bold">Đăng nhập</a>
                </div>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/assets/js/main.js"></script>
</body>
</html>







