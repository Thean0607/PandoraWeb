@{
    Layout = null;
    ViewBag.Title = "Login";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng Nhập - Pandora</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/assets/css/global.css">
    <link rel="stylesheet" href="~/assets/css/components/buttons.css">
    <link rel="stylesheet" href="~/assets/css/components/navbar.css">
    <link rel="stylesheet" href="~/assets/css/components/product-card.css">
    <link rel="stylesheet" href="~/assets/css/components/footer.css">
    <link rel="stylesheet" href="~/assets/css/components/forms.css">
    <link rel="stylesheet" href="~/assets/css/components/quantity-input.css">
    <link rel="stylesheet" href="~/assets/css/components/section-title.css">
    <link rel="stylesheet" href="~/assets/css/components/breadcrumb.css">
    <link rel="stylesheet" href="~/assets/css/auth.css">
</head>
<body>

    <div class="auth-container">
        <div class="auth-overlay"></div>
        <div class="auth-card">
            <div class="text-center mb-4">
                <a href="@Url.Action("Index", "Home")" class="auth-brand m-0">PANDORA</a>
                <p class="auth-subtitle mt-2">Đăng nhập vào tài khoản của bạn</p>
            </div>
            
            <form method="post" action="@Url.Action("Login", "Account")">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger" role="alert">
                        @ViewBag.Error
                    </div>
                }
                <div class="mb-3">
                    <label class="form-label">Email hoặc Số điện thoại</label>
                    <input type="text" name="loginId" class="form-control py-2" placeholder="Nhập email hoặc SĐT" required autofocus>
                </div>
                <div class="mb-4">
                    <div class="d-flex justify-content-between">
                        <label class="form-label">Mật khẩu</label>
                        <a href="#" class="text-muted fs-7 text-decoration-none">Quên mật khẩu?</a>
                    </div>
                    <input type="password" name="password" class="form-control py-2" placeholder="Nhập mật khẩu" autocomplete="current-password" required>
                </div>
                
                <button type="submit" class="btn btn-gold w-100 py-2 mb-3">Đăng Nhập</button>
                
                <div class="text-center mt-3">
                    <span class="text-muted">Chưa có tài khoản?</span> <a href="@Url.Action("Signup", "Account")" class="text-primary-gold text-decoration-none fw-bold">Đăng ký ngay</a>
                </div>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/assets/js/main.js"></script>
</body>
</html>







