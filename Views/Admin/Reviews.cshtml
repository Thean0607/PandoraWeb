@model IEnumerable<PandoraWeb.Models.Review>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-white">@ViewBag.Title</h1>
</div>

<div class="table-wrapper">
    <table class="table admin-table table-hover">
        <thead>
            <tr>
                <th>Khách Hàng</th>
                <th>Sản Phẩm</th>
                <th>Đánh Giá</th>
                <th>Nội Dung</th>
                <th>Ngày Đăng</th>
                <th>Trạng Thái</th>
                <th class="text-end">Thao Tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold">@item.Customer.FullName</td>
                        <td>
                            @if(item.Product != null) {
                                <a href="#" class="text-info text-decoration-none">@item.Product.ProductName</a>
                            } else {
                                <span class="text-muted">Sản phẩm bị xóa</span>
                            }
                        </td>
                        <td class="text-warning">
                            @for(int i=0; i<item.Rating; i++) { <i class="fas fa-star"></i> }
                            @for(int i=item.Rating; i<5; i++) { <i class="far fa-star"></i> }
                        </td>
                        <td><small class="text-muted">@item.Comment</small></td>
                        <td>@item.ReviewDate.ToString("dd/MM/yyyy")</td>
                        <td>
                            <select class="form-select form-select-sm bg-dark text-white border-secondary status-select" 
                                    onchange="updateReviewStatus(@item.ReviewId, this.value)" 
                                    style="width: 110px; font-size: 0.8rem;">
                                <option value="Pending" @(item.Status == "Pending" ? "selected" : "")>Chờ duyệt</option>
                                <option value="Approved" @(item.Status == "Approved" ? "selected" : "")>Đã duyệt</option>
                                <option value="Rejected" @(item.Status == "Rejected" ? "selected" : "")>Bị ẩn</option>
                            </select>
                        </td>
                        <td class="text-end">
                            <button class="btn btn-icon btn-delete" onclick="deleteReview(@item.ReviewId)">
                                <i class="fas fa-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="7" class="text-center py-4 text-muted">Chưa có đánh giá nào.</td></tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        function updateReviewStatus(id, status) {
            fetch('@Url.Action("UpdateReviewStatus", "Admin")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({ id: id, status: status })
            })
            .then(res => res.json())
            .then(data => {
                if(!data.success) {
                    alert(data.message || 'Có lỗi xảy ra!');
                    location.reload(); 
                }
            })
            .catch(err => { console.error(err); location.reload(); });
        }

        function deleteReview(id) {
            if (confirm('Bạn có chắc chắn muốn xóa đánh giá này?')) {
                fetch('@Url.Action("DeleteReview", "Admin")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: new URLSearchParams({ id: id })
                })
                .then(res => res.json())
                .then(data => {
                    if(data.success) location.reload();
                    else alert(data.message || 'Không thể xóa!');
                })
                .catch(err => console.error(err));
            }
        }
    </script>
}
