@model IEnumerable<PandoraWeb.Models.Customer>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-white">@ViewBag.Title</h1>
    <button class="btn btn-admin">
        <i class="fas fa-file-export"></i> Xuất Dữ Liệu
    </button>
</div>

<div class="table-wrapper">
    <table class="table admin-table table-hover">
        <thead>
            <tr>
                <th>ID</th>
                <th>Họ Tên</th>
                <th>Email</th>
                <th>Số Điện Thoại</th>
                <th>Ngày Đăng Ký</th>
                <th>Trạng Thái</th>
                <th class="text-end">Thao Tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>#@item.CustomerId</td>
                        <td class="fw-bold">@item.FullName</td>
                        <td>@item.Email</td>
                        <td>@(string.IsNullOrEmpty(item.PhoneNumber) ? "-" : item.PhoneNumber)</td>
                        <td>@item.CreatedAt.ToString("dd/MM/yyyy")</td>
                        <td>
                            @if(item.Status == "active") {
                                <span class="badge bg-success">Đang hoạt động</span>
                            } else {
                                <span class="badge bg-secondary">Bị khóa</span>
                            }
                        </td>
                        <td class="text-end">
                            <button class="btn btn-icon btn-edit" title="Sửa thông tin">
                                <i class="fas fa-edit"></i>
                            </button>
                            <button class="btn btn-icon btn-delete" title="Khóa tài khoản">
                                <i class="fas fa-ban"></i>
                            </button>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="7" class="text-center py-4 text-muted">Chưa có khách hàng nào.</td></tr>
            }
        </tbody>
    </table>
</div>
