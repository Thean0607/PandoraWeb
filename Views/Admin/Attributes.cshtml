@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var materials = ViewBag.Materials as IEnumerable<PandoraWeb.Models.Material>;
    var sizes = ViewBag.Sizes as IEnumerable<PandoraWeb.Models.Size>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-white">@ViewBag.Title</h1>
</div>

<div class="admin-card">
    <ul class="nav nav-tabs mb-4 border-secondary" id="attributeTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active bg-transparent text-white border-0 border-bottom border-warning" id="material-tab" data-bs-toggle="tab" data-bs-target="#material" type="button" role="tab">Chất liệu (Materials)</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link bg-transparent text-muted border-0" id="size-tab" data-bs-toggle="tab" data-bs-target="#size" type="button" role="tab">Kích thước (Sizes)</button>
        </li>
    </ul>

    <div class="tab-content" id="attributeTabsContent">
        <!-- Materials Tab -->
        <div class="tab-pane fade show active" id="material" role="tabpanel">
            <div class="text-end mb-3">
                <button class="btn btn-admin" onclick="openAttrModal('material')">
                    <i class="fas fa-plus"></i> Thêm Chất Liệu
                </button>
            </div>
            <div class="table-responsive">
                <table class="table admin-table table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Tên Chất Liệu</th>
                            <th class="text-end">Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (materials != null && materials.Any())
                        {
                            foreach (var item in materials)
                            {
                                <tr>
                                    <td>#@item.MaterialId</td>
                                    <td>@item.MaterialName</td>
                                    <td class="text-end">
                                        <button class="btn btn-icon btn-edit" onclick="openAttrModal('material', @item.MaterialId, '@item.MaterialName')">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <button class="btn btn-icon btn-delete" onclick="deleteAttr('material', @item.MaterialId)">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="3" class="text-center py-3 text-muted">Chưa có dữ liệu.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Sizes Tab -->
        <div class="tab-pane fade" id="size" role="tabpanel">
            <div class="text-end mb-3">
                <button class="btn btn-admin" onclick="openAttrModal('size')">
                    <i class="fas fa-plus"></i> Thêm Kích Thước
                </button>
            </div>
            <div class="table-responsive">
                <table class="table admin-table table-hover">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Kích Thước</th>
                            <th class="text-end">Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (sizes != null && sizes.Any())
                        {
                            foreach (var item in sizes)
                            {
                                <tr>
                                    <td>#@item.SizeId</td>
                                    <td>@item.SizeValue</td>
                                    <td class="text-end">
                                        <button class="btn btn-icon btn-edit" onclick="openAttrModal('size', @item.SizeId, '@item.SizeValue')">
                                            <i class="fas fa-edit"></i>
                                        </button>
                                        <button class="btn btn-icon btn-delete" onclick="deleteAttr('size', @item.SizeId)">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="3" class="text-center py-3 text-muted">Chưa có dữ liệu.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="attrModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="attrModalLabel">Thêm Thuộc Tính</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body admin-form">
                <input type="hidden" id="attrType" value="" />
                <input type="hidden" id="attrId" value="" />
                <div class="mb-3">
                    <label for="attrName" class="form-label" id="attrNameLabel">Giá trị <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="attrName" required>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-admin" onclick="saveAttr()">Lưu lại</button>
            </div>
        </div>
    </div>
</div>

<style>
    /* Custom styling for nav tabs in admin layout */
    .nav-tabs .nav-link {
        font-weight: 600;
        padding: 12px 20px;
        transition: all 0.2s;
    }
    .nav-tabs .nav-link:hover {
        color: #fff !important;
    }
    .nav-tabs .nav-link.active {
        border-bottom: 2px solid var(--admin-accent) !important;
        color: var(--admin-accent) !important;
    }
</style>

@section Scripts {
    <script>
        const attrModal = new bootstrap.Modal(document.getElementById('attrModal'));
        
        // Handling tab active states visually
        document.querySelectorAll('.nav-tabs .nav-link').forEach(link => {
            link.addEventListener('click', function() {
                document.querySelectorAll('.nav-tabs .nav-link').forEach(l => {
                    l.classList.remove('border-bottom', 'border-warning', 'text-white');
                    l.classList.add('text-muted');
                });
                this.classList.add('border-bottom', 'border-warning', 'text-white');
                this.classList.remove('text-muted');
            });
        });

        function openAttrModal(type, id = '', name = '') {
            document.getElementById('attrType').value = type;
            document.getElementById('attrId').value = id;
            document.getElementById('attrName').value = name;
            
            const title = type === 'material' ? 'Chất Liệu' : 'Kích Thước';
            document.getElementById('attrModalLabel').innerText = id ? `Cập nhật ${title}` : `Thêm ${title}`;
            document.getElementById('attrNameLabel').innerHTML = `Tên ${title.toLowerCase()} <span class="text-danger">*</span>`;
            
            attrModal.show();
        }

        function saveAttr() {
            const type = document.getElementById('attrType').value;
            const id = document.getElementById('attrId').value;
            const name = document.getElementById('attrName').value.trim();
            
            if (!name) {
                alert('Vui lòng nhập giá trị.');
                return;
            }

            const url = type === 'material' ? '@Url.Action("SaveMaterial", "Admin")' : '@Url.Action("SaveSize", "Admin")';

            fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({ id: id, name: name })
            })
            .then(res => res.json())
            .then(data => {
                if(data.success) location.reload();
                else alert('Có lỗi xảy ra!');
            })
            .catch(err => console.error(err));
        }

        function deleteAttr(type, id) {
            if (confirm('Bạn có chắc chắn muốn xóa?')) {
                const url = type === 'material' ? '@Url.Action("DeleteMaterial", "Admin")' : '@Url.Action("DeleteSize", "Admin")';
                fetch(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: new URLSearchParams({ id: id })
                })
                .then(res => res.json())
                .then(data => {
                    if(data.success) location.reload();
                    else alert(data.message || 'Không thể xóa!');
                })
                .catch(err => console.error(err));
            }
        }
    </script>
}
