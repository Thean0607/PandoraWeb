@model IEnumerable<PandoraWeb.Models.Banner>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-white">@ViewBag.Title</h1>
    <button class="btn btn-admin">
        <i class="fas fa-plus"></i> Thêm Banner
    </button>
</div>

<div class="table-wrapper">
    <table class="table admin-table table-hover">
        <thead>
            <tr>
                <th>Thứ Tự</th>
                <th>Hình Ảnh</th>
                <th>Tiêu Đề</th>
                <th>Trạng Thái</th>
                <th class="text-end">Thao Tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.DisplayOrder</td>
                        <td><img src="~/@item.ImageUrl" style="height:40px; border-radius:4px;" /></td>
                        <td class="fw-bold">@item.Title</td>
                        <td>
                            @if(item.IsActive) { <span class="badge bg-success">Hiển thị</span> }
                            else { <span class="badge bg-secondary">Đã ẩn</span> }
                        </td>
                        <td class="text-end">
                            <button class="btn btn-icon btn-edit"><i class="fas fa-edit"></i></button>
                            <button class="btn btn-icon btn-delete"><i class="fas fa-trash"></i></button>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="5" class="text-center py-4 text-muted">Chưa có banner nào.</td></tr>
            }
        </tbody>
    </table>
</div>
