@model IEnumerable<PandoraWeb.Models.Faq>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-white">@ViewBag.Title</h1>
    <button class="btn btn-admin">
        <i class="fas fa-plus"></i> Thêm Câu Hỏi
    </button>
</div>

<div class="table-wrapper">
    <table class="table admin-table table-hover">
        <thead>
            <tr>
                <th style="width: 50px;">Thứ Tự</th>
                <th>Câu Hỏi</th>
                <th>Câu Trả Lời</th>
                <th>Trạng Thái</th>
                <th class="text-end">Thao Tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.DisplayOrder</td>
                        <td class="fw-bold text-warning">@item.Question</td>
                        <td><small class="text-muted">@(item.Answer.Length > 100 ? item.Answer.Substring(0, 100) + "..." : item.Answer)</small></td>
                        <td>
                            @if(item.IsActive) { <span class="badge bg-success">Hiện</span> }
                            else { <span class="badge bg-secondary">Ẩn</span> }
                        </td>
                        <td class="text-end">
                            <button class="btn btn-icon btn-edit"><i class="fas fa-edit"></i></button>
                            <button class="btn btn-icon btn-delete"><i class="fas fa-trash"></i></button>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="5" class="text-center py-4 text-muted">Chưa có dữ liệu FAQ.</td></tr>
            }
        </tbody>
    </table>
</div>
