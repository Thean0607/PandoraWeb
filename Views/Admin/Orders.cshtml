@model IEnumerable<PandoraWeb.Models.Order>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-white">@ViewBag.Title</h1>
    <button class="btn btn-admin">
        <i class="fas fa-file-export"></i> Xuất Dữ Liệu
    </button>
</div>

<div class="table-wrapper">
    <table class="table admin-table table-hover">
        <thead>
            <tr>
                <th>Mã Đơn</th>
                <th>Khách Hàng</th>
                <th>Ngày Đặt</th>
                <th>Tổng Tiền</th>
                <th>Thanh Toán</th>
                <th>Trạng Thái</th>
                <th class="text-end">Thao Tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>#@item.OrderId</td>
                        <td>@(item.Customer != null ? item.Customer.FullName : "Khách vãng lai")</td>
                        <td>@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-warning fw-bold">@item.TotalAmount.ToString("N0") ₫</td>
                        <td>
                            @if(item.PaymentStatus == "Paid") {
                                <span class="badge bg-success">Đã thanh toán</span>
                            } else {
                                <span class="badge bg-secondary">Chưa thanh toán</span>
                            }
                        </td>
                        <td>
                            <select class="form-select form-select-sm bg-dark text-white border-secondary status-select" 
                                    onchange="updateStatus(@item.OrderId, this.value)" 
                                    data-original="@item.OrderStatus"
                                    style="width: 130px; font-size: 0.8rem;">
                                <option value="Pending" @(item.OrderStatus == "Pending" ? "selected" : "")>Chờ xử lý</option>
                                <option value="Processing" @(item.OrderStatus == "Processing" ? "selected" : "")>Đang xử lý</option>
                                <option value="Shipped" @(item.OrderStatus == "Shipped" ? "selected" : "")>Đang giao</option>
                                <option value="Delivered" @(item.OrderStatus == "Delivered" ? "selected" : "")>Đã giao</option>
                                <option value="Cancelled" @(item.OrderStatus == "Cancelled" ? "selected" : "")>Đã hủy</option>
                            </select>
                        </td>
                        <td class="text-end">
                            <a href="#" class="btn btn-icon btn-edit" title="Xem chi tiết">
                                <i class="fas fa-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="7" class="text-center py-4 text-muted">Chưa có đơn hàng nào.</td></tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        function updateStatus(id, status) {
            fetch('@Url.Action("UpdateOrderStatus", "Admin")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: new URLSearchParams({ id: id, status: status })
            })
            .then(res => res.json())
            .then(data => {
                if(data.success) {
                    alert('Đã cập nhật trạng thái đơn hàng!');
                } else {
                    alert(data.message || 'Có lỗi xảy ra!');
                    location.reload(); // Reload to reset select
                }
            })
            .catch(err => {
                console.error(err);
                location.reload();
            });
        }
    </script>
}
