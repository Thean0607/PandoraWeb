@model IEnumerable<PandoraWeb.Models.Order>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-white">@ViewBag.Title</h1>
</div>

<div class="table-wrapper">
    <table class="table admin-table table-hover">
        <thead>
            <tr>
                <th>Mã Đơn</th>
                <th>Khách Hàng</th>
                <th>Ngày Đặt</th>
                <th>Tổng Hoàn</th>
                <th>Phương Thức</th>
                <th>Trạng Thái</th>
                <th class="text-end">Xử Lý</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>#@item.OrderId</td>
                        <td>@(item.Customer != null ? item.Customer.FullName : "Khách vãng lai")</td>
                        <td>@item.OrderDate.ToString("dd/MM/yyyy")</td>
                        <td class="text-danger fw-bold">@item.TotalAmount.ToString("N0") ₫</td>
                        <td>@item.PaymentMethod</td>
                        <td>
                            <span class="badge bg-danger">@item.OrderStatus</span>
                        </td>
                        <td class="text-end">
                            @if(item.PaymentStatus == "Paid") {
                                <button class="btn btn-sm btn-outline-warning">Thực hiện hoàn tiền</button>
                            } else {
                                <span class="text-muted"><small>Không cần hoàn tiền</small></span>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="7" class="text-center py-4 text-muted">Không có dữ liệu hoàn trả/hủy.</td></tr>
            }
        </tbody>
    </table>
</div>
