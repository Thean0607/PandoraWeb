@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "OrderSuccess";
}

<!-- Success Content -->
    <div class="container-fluid px-4 px-lg-5 py-5 mt-5 bg-light min-vh-100 d-flex justify-content-center align-items-center">
        <div class="card border-0 shadow-sm p-4 p-md-5 w-100 mt-5" style="max-width: 600px;">
            <div class="text-center mb-4">
                <div class="rounded-circle bg-success text-white d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                    <i class="fas fa-check fs-1"></i>
                </div>
                <h2 class="font-serif text-success mb-2">Đặt Hàng Thành Công!</h2>
                <p class="text-muted">Cảm ơn bạn đã lựa chọn Pandora. Đơn hàng của bạn đã được xác nhận và đang trong quá trình xử lý.</p>
            </div>

            <div class="bg-secondary-soft p-4 rounded mb-4">
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Mã đơn hàng:</span>
                    <span class="fw-bold">#PAN847291</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Ngày đặt:</span>
                    <span class="fw-bold">@DateTime.Now.ToString("dd/MM/yyyy")</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Tổng thanh toán:</span>
                    <span class="fw-bold text-primary-gold fs-5">22,400,000 ₫</span>
                </div>
                <div class="d-flex justify-content-between">
                    <span class="text-muted">Phương thức:</span>
                    <span class="fw-bold">Thanh toán khi nhận hàng (COD)</span>
                </div>
            </div>

            <div class="mb-5">
                <h5 class="font-serif mb-4 text-center">Các bước tiếp theo</h5>
                <div class="d-flex mb-3">
                    <div class="text-primary-gold me-3 mt-1">
                        <i class="fas fa-envelope fs-4"></i>
                    </div>
                    <div>
                        <div class="fw-bold">Xác nhận Email</div>
                        <p class="text-muted small mb-0">Một email xác nhận chi tiết đơn hàng đã được gửi đến email của bạn.</p>
                    </div>
                </div>
                <div class="d-flex mb-3">
                    <div class="text-primary-gold me-3 mt-1">
                        <i class="fas fa-box fs-4"></i>
                    </div>
                    <div>
                        <div class="fw-bold">Chuẩn bị hàng</div>
                        <p class="text-muted small mb-0">Chúng tôi sẽ đóng gói sản phẩm cẩn thận trong hộp quà Pandora tiêu chuẩn.</p>
                    </div>
                </div>
                <div class="d-flex mb-3">
                    <div class="text-primary-gold me-3 mt-1">
                        <i class="fas fa-truck fs-4"></i>
                    </div>
                    <div>
                        <div class="fw-bold">Giao hàng</div>
                        <p class="text-muted small mb-0">Thời gian giao hàng dự kiến từ 2-3 ngày làm việc.</p>
                    </div>
                </div>
            </div>

            <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center mt-auto">
                <a href="@Url.Action("Orders", "Order")" class="btn btn-outline-gold px-4 py-2">Xem Đơn Hàng</a>
                <a href="@Url.Action("Category", "Product")" class="btn btn-gold px-4 py-2">Tiếp Tục Mua Sắm</a>
            </div>
        </div>
    </div>

    <!-- Footer Minimal -->

