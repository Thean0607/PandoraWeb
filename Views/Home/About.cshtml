@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "About";
}

<!-- Hero Section -->
    <section class="about-hero">
        <div class="container">
            <h1 class="about-hero-title">Câu Chuyện Của Pandora</h1>
            <p class="about-hero-subtitle">Hơn một thập kỷ chế tác những tuyệt tác trang sức, tôn vinh vẻ đẹp và câu chuyện riêng của mỗi người phụ nữ.</p>
        </div>
    </section>

    <!-- Our Story Section -->
    <section class="story-section">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6 mb-4 mb-lg-0">
                    <img src="https://images.unsplash.com/photo-1573408301145-b98c46544bc6?q=80&w=800&auto=format&fit=crop" alt="Pandora Craftsmanship" class="story-img">
                </div>
                <div class="col-lg-6">
                    <div class="story-text">
                        <h2 class="story-title">Nghệ Thuật Chế Tác Thủ Công</h2>
                        <p class="text-muted mb-4">Khởi nguồn từ một cửa hàng trang sức nhỏ tại Copenhagen, Đan Mạch, Pandora đã vươn lên trở thành một trong những thương hiệu trang sức được yêu thích nhất toàn cầu. Chúng tôi tin rằng mỗi người phụ nữ đều mang trong mình những câu chuyện độc đáo đáng được trân trọng và lưu giữ.</p>
                        <p class="text-muted mb-4">Từng chi tiết nhỏ trên các món trang sức của Pandora đều được chế tác thủ công với sự tỉ mỉ tối đa từ những vật liệu chất lượng cao nhất như bạc 925, vàng 14k và đá quý tự nhiên. Đó không chỉ là trang sức, đó là nghệ thuật, là kỷ niệm, là bản sắc cá nhân.</p>
                        <a href="@Url.Action("Category", "Product")" class="btn btn-outline-gold mt-2">Khám Phá Bộ Sưu Tập</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats Section -->
    <section class="stats-section">
        <div class="container">
            <div class="row">
                <div class="col-md-3 col-6">
                    <div class="stat-item">
                        <div class="stat-number">1982</div>
                        <div class="stat-label">Năm Thành Lập</div>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="stat-item">
                        <div class="stat-number">100+</div>
                        <div class="stat-label">Quốc Gia Toàn Cầu</div>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="stat-item">
                        <div class="stat-number">7,000+</div>
                        <div class="stat-label">Điểm Bán Lẻ</div>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="stat-item">
                        <div class="stat-number">26,000+</div>
                        <div class="stat-label">Nhân Viên Khắp Nơi</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Core Values Section -->
    <section class="values-section">
        <div class="container">
            <div class="text-center mb-5">
                <h2 class="story-title">Giá Trị Cốt Lõi</h2>
                <p class="text-muted max-w-600 mx-auto">Những nguyên tắc định hướng mọi hoạt động và thiết kế của chúng tôi.</p>
            </div>
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="value-card border rounded">
                        <i class="fas fa-gem value-icon"></i>
                        <h3 class="value-title">Chất Lượng Đỉnh Cao</h3>
                        <p class="text-muted">Mỗi thiết kế đều trải qua quy trình kiểm định nghiêm ngặt để đảm bảo độ bền và vẻ đẹp hoàn mỹ nhất.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="value-card border rounded">
                        <i class="fas fa-leaf value-icon"></i>
                        <h3 class="value-title">Phát Triển Bền Vững</h3>
                        <p class="text-muted">Chúng tôi cam kết sử dụng vật liệu tái chế và giảm thiểu tối đa tác động đến môi trường trong quy trình sản xuất.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="value-card border rounded">
                        <i class="fas fa-heart value-icon"></i>
                        <h3 class="value-title">Tôn Vinh Cá Tính</h3>
                        <p class="text-muted">Thiết kế linh hoạt cho phép người đeo tự do sáng tạo và thể hiện cái tôi độc nhất của bản thân.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->

