@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Contact";
}

<!-- Breadcrumb -->
    <div class="breadcrumb-wrap mt-5 pt-5 mb-0">
        <div class="container-fluid px-4 px-lg-5 mt-4">
            <h1 class="breadcrumb-title font-serif">Liên Hệ Chúng Tôi</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Trang Chủ</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Liên Hệ</li>
                </ol>
            </nav>
        </div>
    </div>

    <!-- Contact Content -->
    <section class="py-5">
        <div class="container-fluid px-4 px-lg-5">
            <div class="row g-5">
                <!-- Contact Info -->
                <div class="col-lg-5">
                    <h2 class="font-serif mb-4">Thông Tin Cửa Hàng</h2>
                    <p class="text-muted mb-5">Chúng tôi luôn sẵn sàng lắng nghe và giải đáp mọi thắc mắc của bạn. Hãy liên hệ với chúng tôi qua các kênh dưới đây hoặc ghé thăm cửa hàng trực tiếp.</p>
                    
                    <div class="d-flex mb-4">
                        <div class="bg-primary-gold text-white rounded-circle d-flex align-items-center justify-content-center me-3 flex-shrink-0" style="width: 50px; height: 50px;">
                            <i class="fas fa-map-marker-alt fs-5"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-1">Địa chỉ</h5>
                            <p class="text-muted mb-0">Tầng 1, TTTM Vincom Center, 72 Lê Thánh Tôn, Quận 1, TP. Hồ Chí Minh</p>
                        </div>
                    </div>
                    
                    <div class="d-flex mb-4">
                        <div class="bg-primary-gold text-white rounded-circle d-flex align-items-center justify-content-center me-3 flex-shrink-0" style="width: 50px; height: 50px;">
                            <i class="fas fa-phone-alt fs-5"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-1">Điện thoại</h5>
                            <p class="text-muted mb-0">1900 1234 567 (Tư vấn miễn phí)</p>
                        </div>
                    </div>
                    
                    <div class="d-flex mb-4">
                        <div class="bg-primary-gold text-white rounded-circle d-flex align-items-center justify-content-center me-3 flex-shrink-0" style="width: 50px; height: 50px;">
                            <i class="fas fa-envelope fs-5"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-1">Email</h5>
                            <p class="text-muted mb-0">support@pandora.vn</p>
                        </div>
                    </div>

                    <hr class="my-4">
                    <h5 class="fw-bold mb-3">Giờ Mở Cửa</h5>
                    <ul class="list-unstyled text-muted">
                        <li class="d-flex justify-content-between mb-2"><span>Thứ 2 - Thứ 6:</span> <span>09:00 - 21:00</span></li>
                        <li class="d-flex justify-content-between mb-2"><span>Thứ 7 - Chủ Nhật:</span> <span>09:00 - 22:00</span></li>
                    </ul>
                </div>

                <!-- Contact Form -->
                <div class="col-lg-7">
                    <div class="card border-0 shadow-sm p-4 p-md-5">
                        <h3 class="font-serif mb-4">Gửi Tin Nhắn</h3>
                        <form>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Họ và tên *</label>
                                    <input type="text" class="form-control" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Email *</label>
                                    <input type="email" class="form-control" required>
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Tiêu đề</label>
                                    <input type="text" class="form-control">
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Nội dung tin nhắn *</label>
                                    <textarea class="form-control" rows="5" required></textarea>
                                </div>
                                <div class="col-12 mt-4">
                                    <button type="submit" class="btn btn-gold px-5 py-2">Gửi Tin Nhắn</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Map -->
    <div class="container-fluid px-0">
        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3919.4602324217646!2d106.69910541480112!3d10.776019462145325!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x31752f4738bbd1ad%3A0xc621b193ddb29358!2sVincom%20Center%20%C4%90%E1%BB%93ng%20Kh%E1%BB%9Fi!5e0!3m2!1sen!2s!4v1654848392849!5m2!1sen!2s" width="100%" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
    </div>

    <!-- Footer -->

